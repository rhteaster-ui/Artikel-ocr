# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINII_API_KEY: Kunci API alternatif jika kunci bawaan dibatasi atau bermasalah.
# Anda dapat mengaturnya di panel Secrets/Settings AI Studio dengan nama variabel GEMINII_API_KEY.
GEMINII_API_KEY="KUNCI_API_GEMINI_ANDA"

# GEMINI_API_KEY_SECONDARY: Kunci API kedua untuk mendukung rotasi kunci otomatis pada setiap topik/artikel baru.
# Sesi percakapan (chat) yang aktif akan tetap konsisten menggunakan kunci yang sama untuk menjaga konteks.
GEMINI_API_KEY_SECONDARY="KUNCI_API_KEDUA_UNTUK_ROTASI"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# iLovePDF API Keys: Diperlukan jika Anda ingin memproses OCR dokumen PDF/Gambar menggunakan iLovePDF API secara native.
# Jika tidak disediakan, sistem akan menggunakan Fallback Gemini Multimodal OCR yang cerdas secara otomatis.
ILOVEPDF_PUBLIC_KEY=""
ILOVEPDF_SECRET_KEY=""

